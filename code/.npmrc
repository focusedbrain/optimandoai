# Hoisted node_modules for Electron packaging: electron-builder copies from
# apps/electron-vite-project/node_modules. With default pnpm layout, transitive
# deps (e.g. whatwg-url for node-fetch) live in .pnpm and are not resolvable
# at runtime. Hoisted layout puts them in node_modules so they get packaged.
node-linker=hoisted
