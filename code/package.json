{
  "name": "@repo/root",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ],
    "overrides": {
      "electron": "30.5.1"
    }
  },
  "version": "0.0.1",
  "scripts": {
    "test": "vitest --passWithNoTests",
    "test:email-lifecycle": "vitest run apps/electron-vite-project/electron/main/email/domain/mailboxLifecycleMapping.test.ts apps/electron-vite-project/electron/main/email/domain/customImapSmtpPayloadValidation.test.ts apps/electron-vite-project/electron/main/email/domain/syncLastSyncAnchorPolicy.test.ts apps/electron-vite-project/electron/main/email/domain/securityModeNormalize.test.ts apps/electron-vite-project/electron/main/email/__tests__/inboxOrchestratorRemoteQueue.enqueue.test.ts apps/electron-vite-project/electron/main/email/__tests__/inboxLifecycleEngine.tick.test.ts apps/electron-vite-project/electron/main/email/__tests__/emailInboxAttachmentInvariants.test.ts apps/electron-vite-project/electron/main/email/__tests__/messageRouter.ingestTransaction.test.ts apps/electron-vite-project/electron/main/email/googleOAuthBuiltin.test.ts apps/electron-vite-project/electron/main/email/gmailOAuthResolve.test.ts apps/electron-vite-project/src/components/bulkInboxAttachmentHydration.test.ts apps/electron-vite-project/src/utils/syncFailureUi.test.ts apps/extension-chromium/src/shared/email/connectEmail.launch.test.ts",
    "test:webmcp": "vitest run apps/extension-chromium/src/vault/autofill/webMcpAdapter.test.ts apps/extension-chromium/src/vault/autofill/__tests__/background-sender-gate.test.ts apps/extension-chromium/src/vault/autofill/__tests__/webmcp-isolation.test.ts",
    "test:webmcp:ci": "vitest run --reporter=verbose apps/extension-chromium/src/vault/autofill/webMcpAdapter.test.ts apps/extension-chromium/src/vault/autofill/__tests__/background-sender-gate.test.ts apps/extension-chromium/src/vault/autofill/__tests__/webmcp-isolation.test.ts",
    "test:kill-switch": "vitest run apps/extension-chromium/src/vault/autofill/__tests__/writes-kill-switch.test.ts",
    "test:kill-switch:ci": "vitest run --reporter=verbose apps/extension-chromium/src/vault/autofill/__tests__/writes-kill-switch.test.ts",
    "test:redaction": "vitest run apps/extension-chromium/src/vault/autofill/__tests__/log-redaction-proof.test.ts",
    "test:scan-caps": "vitest run apps/extension-chromium/src/vault/autofill/__tests__/scan-dos-caps.test.ts",
    "test:quarantine": "vitest run apps/extension-chromium/src/vault/autofill/committer.test.ts apps/extension-chromium/src/vault/autofill/__tests__/hardening.test.ts apps/extension-chromium/src/vault/autofill/__tests__/security-regression.test.ts apps/extension-chromium/src/vault/autofill/fieldScanner.test.ts",
    "check:write-boundary": "bash scripts/check-write-boundary.sh",
    "check:write-boundary:win": "powershell -ExecutionPolicy Bypass -File scripts/check-write-boundary.ps1",
    "release:manifest": "node scripts/release/generate-manifest.mjs",
    "release:sign": "node scripts/release/sign-manifest.mjs",
    "release:verify": "node scripts/release/verify-manifest.mjs",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "handshake:repair-counterparty": "tsx apps/electron-vite-project/scripts/repair-handshake-counterparty.ts"
  },
  "devDependencies": {
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.41.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "canvas": "^3.2.0"
  }
}
