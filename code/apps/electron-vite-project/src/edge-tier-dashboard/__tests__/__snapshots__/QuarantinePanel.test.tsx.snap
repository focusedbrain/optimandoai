// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`sandbox audit styling snapshots > QuarantinePanel uses monospace muted palette 1`] = `"<div data-testid="edge-dashboard-quarantine" style="background:#f4f4f5;border:1px solid #d4d4d8;border-radius:6px;padding:16px;color:#52525b;font-size:12px"><header style="margin-bottom:16px"><h3 style="margin:0 0 4px;font-size:14px;font-weight:600;color:#3f3f46;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace">Quarantined Messages</h3><p style="font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;font-size:11px;color:#71717a;margin:0">Audit trail only — view reports and bodies in the sandbox orchestrator.</p></header><div data-testid="quarantine-replica-summary" style="margin-bottom:16px"><button type="button" data-testid="quarantine-replica-count-11111111-1111-4111-8111-111111111111" style="display:block;width:100%;text-align:left;margin-bottom:6px;padding:8px 10px;border-radius:4px;border:1px solid #d4d4d8;background:#e4e4e7;cursor:pointer;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;font-size:11px;color:#71717a">1 message quarantined — <span style="color:#71717a">11111111-1111-4111-8111-111111111111</span></button></div><div data-testid="quarantine-list"><h4 style="margin:0 0 8px;font-size:12px;font-weight:600;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;color:#3f3f46">Entries for 11111111-1111-4111-8111-111111111111</h4><table style="width:100%;border-collapse:collapse;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;font-size:11px;color:#71717a"><thead><tr style="border-bottom:1px solid #d4d4d8"><th style="padding:6px 8px;text-align:left">Timestamp</th><th style="padding:6px 8px;text-align:left">Sender (sender-reported)</th><th style="padding:6px 8px;text-align:left">Subject</th><th style="padding:6px 8px;text-align:left">Failed role</th><th style="padding:6px 8px;text-align:left">Actions</th></tr></thead><tbody><tr data-testid="quarantine-row-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" style="border-bottom:1px solid #d4d4d8"><td style="padding:6px 8px;white-space:nowrap">24.5.2026, 14:00:00</td><td style="padding:6px 8px">sender@example.com</td><td style="padding:6px 8px">Test subject line</td><td style="padding:6px 8px">depackager</td><td style="padding:6px 8px"><div style="display:flex;flex-direction:column;gap:4px"><button type="button" data-testid="quarantine-view-report-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" style="padding:4px 8px;font-size:10px;border-radius:4px;border:1px solid #d4d4d8;background:#e4e4e7;color:#52525b;cursor:pointer;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;text-align:left">View report in sandbox</button><button type="button" data-testid="quarantine-view-body-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" style="padding:4px 8px;font-size:10px;border-radius:4px;border:1px solid #d4d4d8;background:#e4e4e7;color:#52525b;cursor:pointer;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;text-align:left">View message body in sandbox</button></div></td></tr></tbody></table></div></div>"`;

exports[`sandbox audit styling snapshots > SandboxViewerModal uses monospace muted styling, not inbox cards 1`] = `
"<div data-testid="sandbox-viewer-modal" data-sandbox-mode="diagnostic_report" style="position:fixed;inset:0;background:rgba(24, 24, 27, 0.72);display:flex;align-items:center;justify-content:center;z-index:10000;padding:24px" role="dialog" aria-modal="true" aria-label="Diagnostic Report"><div data-testid="sandbox-viewer-panel" style="width:min(920px, 100%);max-height:85vh;background:#f4f4f5;border:1px solid #d4d4d8;border-radius:8px;display:flex;flex-direction:column;overflow:hidden"><header style="padding:12px 16px;border-bottom:1px solid #d4d4d8;display:flex;justify-content:space-between;align-items:center;gap:12px"><div><h2 style="margin:0;font-size:14px;font-weight:600;color:#3f3f46;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace">Diagnostic Report</h2><p style="font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;font-size:11px;color:#71717a;margin:4px 0 0">Sandbox-isolated view — plain text only</p></div><button type="button" data-testid="sandbox-viewer-close" style="padding:4px 10px;font-size:11px;border-radius:4px;border:1px solid #d4d4d8;background:#e4e4e7;color:#52525b;cursor:pointer;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace">Close</button></header><pre data-testid="sandbox-viewer-content" style="margin:0;padding:16px;overflow:auto;flex:1;font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;font-size:11px;line-height:1.45;color:#52525b;white-space:pre-wrap;word-break:break-word;background:#fafafa">{
  &quot;report_v&quot;: 1
}</pre></div></div>"
`;
