// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DashboardShellView > matches snapshot for empty state when edge tier disabled 1`] = `"<div data-testid="edge-dashboard-empty" style="max-width:560px;margin:48px auto;padding:24px;text-align:center;border:1px dashed var(--border);border-radius:10px"><h2 style="margin-top:0;font-size:18px">Edge tier is not configured</h2><p style="color:var(--text-secondary);margin-bottom:20px">Start the wizard to deploy your first replica.</p><button type="button" data-testid="edge-dashboard-launch-wizard" style="padding:8px 16px;border-radius:8px;border:1px solid #6366f1;background:#eef2ff;cursor:pointer;font-weight:600">Set up edge tier</button></div>"`;

exports[`DashboardShellView > matches snapshot for list state with replicas and verifications tab 1`] = `"<div data-testid="edge-dashboard" style="padding:24px 32px;max-width:960px;margin:0 auto"><header style="margin-bottom:20px"><h1 style="margin:0 0 4px;font-size:20px">Edge tier</h1><p style="margin:0;color:var(--text-secondary);font-size:13px">Replica health and recent certificate verifications.</p></header><div style="display:flex;gap:8px;margin-bottom:16px"><button type="button" data-testid="edge-dashboard-tab-replicas" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:#e2e8f0;font-weight:600;cursor:pointer">Replicas</button><button type="button" data-testid="edge-dashboard-tab-verifications" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;font-weight:400;cursor:pointer">Verifications</button></div><div data-testid="edge-dashboard-replicas"><h3 style="margin:0 0 12px;font-size:14px;font-weight:600">Replicas</h3><table style="width:100%;border-collapse:collapse;font-size:12px"><thead><tr style="text-align:left;border-bottom:1px solid var(--border)"><th style="padding:6px 8px">Host</th><th style="padding:6px 8px">Health</th><th style="padding:6px 8px">Last cert</th><th style="padding:6px 8px">Certs/min</th><th style="padding:6px 8px"></th></tr></thead><tbody><tr style="border-bottom:1px solid var(--border)"><td style="padding:6px 8px"><div>edge.example:18100</div><div style="color:var(--text-secondary);font-family:ui-monospace, monospace;font-size:11px">11111111-1111-4111-8111-111111111111</div></td><td style="padding:6px 8px;color:#22c55e;font-weight:600">Healthy</td><td style="padding:6px 8px;white-space:nowrap">24.5.2026, 14:01:00</td><td style="padding:6px 8px">1.2</td><td style="padding:6px 8px"><button type="button" data-testid="replica-view-details-11111111-1111-4111-8111-111111111111" style="padding:4px 10px;font-size:11px;border-radius:6px;border:1px solid var(--border);background:transparent;cursor:pointer">View details</button></td></tr></tbody></table></div></div>"`;

exports[`ReplicaDetail > matches snapshot for detail state 1`] = `"<div data-testid="edge-replica-detail" role="dialog" aria-modal="true" style="position:fixed;inset:0;background:rgba(15,23,42,0.45);display:flex;align-items:center;justify-content:center;z-index:1000"><div style="width:min(640px, 92vw);max-height:80vh;overflow:auto;background:var(--bg-primary, #fff);border-radius:10px;border:1px solid var(--border);padding:20px;box-shadow:0 12px 40px rgba(15,23,42,0.2)"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px"><h2 style="margin:0;font-size:16px">Replica details</h2><button type="button" aria-label="Close">✕</button></div><dl style="margin:0;font-size:13px;display:grid;grid-template-columns:140px 1fr;row-gap:8px"><dt style="color:var(--text-secondary)">Host</dt><dd style="margin:0">edge.example:18100</dd><dt style="color:var(--text-secondary)">Edge pod ID</dt><dd style="margin:0;font-family:ui-monospace, monospace">11111111-1111-4111-8111-111111111111</dd><dt style="color:var(--text-secondary)">Public key</dt><dd style="margin:0;font-family:ui-monospace, monospace;word-break:break-all">ed25519:aa</dd><dt style="color:var(--text-secondary)">Health</dt><dd style="margin:0;color:#22c55e;font-weight:600">Healthy</dd><dt style="color:var(--text-secondary)">Last health check</dt><dd style="margin:0">24.5.2026, 14:00:00</dd><dt style="color:var(--text-secondary)">Last cert issued</dt><dd style="margin:0">24.5.2026, 14:01:00</dd></dl><div style="margin-top:20px"><div style="display:flex;align-items:center;gap:8px;margin-bottom:8px"><strong style="font-size:13px">Recent remote logs</strong><button type="button" data-testid="replica-fetch-logs" style="padding:4px 10px;font-size:11px;border-radius:6px;border:1px solid var(--border)">Fetch logs</button></div><p style="color:var(--text-secondary);font-size:12px;margin:0">Logs are fetched on demand via SSH (not streamed).</p></div></div></div>"`;
