// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DashboardShellView > matches snapshot for empty state when edge tier disabled 1`] = `"<div data-testid="edge-dashboard-empty" style="max-width:560px;margin:48px auto;padding:24px;text-align:center;border:1px dashed var(--border);border-radius:10px"><h2 style="margin-top:0;font-size:18px">Edge Ingestor is not configured</h2><p style="color:var(--text-secondary);margin-bottom:20px">Start the wizard to deploy the edge ingestor with the depackaging unit and validator off band on a VPS server.</p><button type="button" data-testid="edge-dashboard-launch-wizard" style="padding:8px 16px;border-radius:8px;border:1px solid #6366f1;background:#eef2ff;cursor:pointer;font-weight:600">Set up edge ingestor</button></div>"`;

exports[`DashboardShellView > matches snapshot for list state with replicas and verifications tab 1`] = `"<div data-testid="edge-dashboard" style="padding:24px 32px;max-width:960px;margin:0 auto"><header style="margin-bottom:20px"><h1 style="margin:0 0 4px;font-size:20px">Edge Ingestor</h1><p style="margin:0;color:var(--text-secondary);font-size:13px">Off-band replica health and recent certificate verifications.</p></header><section data-testid="edge-global-actions" style="margin-bottom:24px;padding:16px;border-radius:10px;border:1px solid var(--border);background:var(--bg-secondary, #f8fafc)"><h2 style="margin:0 0 12px;font-size:15px">Global actions</h2><div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px"><button type="button" data-testid="global-rotate-keys" style="padding:8px 14px;border-radius:6px;border:1px solid #6366f1;background:#eef2ff;cursor:pointer;opacity:1">Rotate edge keys</button><button type="button" data-testid="global-pause-edge-tier" style="padding:8px 14px;border-radius:6px;border:1px solid #dc2626;background:#fef2f2;color:#b91c1c;cursor:pointer">Pause edge tier</button></div><div data-testid="edge-fallback-policy-settings"><h3 style="margin:0 0 8px;font-size:14px;font-weight:600">Fallback policy</h3><p style="margin:0 0 12px;color:var(--text-secondary);font-size:12px">Applies when all edge replicas are unreachable during ingest.</p><div style="display:flex;flex-direction:column;gap:12px"><label data-testid="fallback-policy-reject" style="display:flex;gap:10px;align-items:flex-start;padding:10px;border-radius:8px;border:1px solid #6366f1;background:#eef2ff;cursor:pointer;opacity:1"><input type="radio" name="fallback-policy" style="margin-top:3px" checked="" value="reject"/><span><strong style="display:block;font-size:13px">Reject when edge is unreachable</strong><span style="font-size:12px;color:var(--text-secondary)">When all edge replicas are unreachable, messages are quarantined and you are alerted. This is the safest choice for high-assurance use.</span></span></label><label data-testid="fallback-policy-downgrade_with_badge" style="display:flex;gap:10px;align-items:flex-start;padding:10px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;opacity:1"><input type="radio" name="fallback-policy" style="margin-top:3px" value="downgrade_with_badge"/><span><strong style="display:block;font-size:13px">Downgrade with badge</strong><span style="font-size:12px;color:var(--text-secondary)">When all edge replicas are unreachable, messages are processed locally only and tagged with a badge in the inbox. Choose this only if you understand that local-only processing gives you weaker guarantees than the edge tier provides.</span></span></label></div></div><div data-testid="edge-known-hosts-settings" style="margin-top:20px"><h3 style="margin:0 0 8px;font-size:14px;font-weight:600">Known hosts</h3><p style="margin:0 0 12px;color:var(--text-secondary);font-size:12px">SSH host key fingerprints trusted for edge VPS connections. Removing an entry forces a fresh trust prompt on the next connect.</p><p style="font-size:12px;color:var(--text-secondary)">Loading…</p></div></section><div style="display:flex;gap:8px;margin-bottom:16px"><button type="button" data-testid="edge-dashboard-tab-replicas" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:#e2e8f0;font-weight:600;cursor:pointer">Replicas</button><button type="button" data-testid="edge-dashboard-tab-verifications" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;font-weight:400;cursor:pointer">Verifications</button><button type="button" data-testid="edge-dashboard-tab-quarantine" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;font-weight:400;cursor:pointer">Quarantine</button></div><div data-testid="edge-dashboard-replicas"><h3 style="margin:0 0 12px;font-size:14px;font-weight:600">Replicas</h3><table style="width:100%;border-collapse:collapse;font-size:12px"><thead><tr style="text-align:left;border-bottom:1px solid var(--border)"><th style="padding:6px 8px">Host</th><th style="padding:6px 8px">Health</th><th style="padding:6px 8px">Last cert</th><th style="padding:6px 8px">Certs/min</th><th style="padding:6px 8px"></th></tr></thead><tbody><tr style="border-bottom:1px solid var(--border)"><td style="padding:6px 8px"><div>edge.example:18100</div><div style="color:var(--text-secondary);font-family:ui-monospace, monospace;font-size:11px">11111111-1111-4111-8111-111111111111</div></td><td style="padding:6px 8px;color:#22c55e;font-weight:600">Healthy</td><td style="padding:6px 8px;white-space:nowrap">24.5.2026, 14:01:00</td><td style="padding:6px 8px">1.2</td><td style="padding:6px 8px"><div style="display:flex;gap:6px;align-items:center"><button type="button" data-testid="replica-view-details-11111111-1111-4111-8111-111111111111" style="padding:4px 10px;font-size:11px;border-radius:6px;border:1px solid var(--border);background:transparent;cursor:pointer">View details</button><div style="position:relative;display:inline-block"><button type="button" data-testid="replica-kebab-11111111-1111-4111-8111-111111111111" aria-label="Replica actions" style="padding:4px 8px;border-radius:6px;border:1px solid var(--border);background:transparent;cursor:pointer">⋮</button></div></div></td></tr></tbody></table></div></div>"`;

exports[`ReplicaDetail > matches snapshot for detail state 1`] = `"<div data-testid="edge-replica-detail" role="dialog" aria-modal="true" style="position:fixed;inset:0;background:rgba(15,23,42,0.45);display:flex;align-items:center;justify-content:center;z-index:1000"><div style="width:min(640px, 92vw);max-height:80vh;overflow:auto;background:var(--bg-primary, #fff);border-radius:10px;border:1px solid var(--border);padding:20px;box-shadow:0 12px 40px rgba(15,23,42,0.2)"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px"><h2 style="margin:0;font-size:16px">Replica details</h2><button type="button" aria-label="Close">✕</button></div><dl style="margin:0;font-size:13px;display:grid;grid-template-columns:140px 1fr;row-gap:8px"><dt style="color:var(--text-secondary)">Host</dt><dd style="margin:0">edge.example:18100</dd><dt style="color:var(--text-secondary)">Edge pod ID</dt><dd style="margin:0;font-family:ui-monospace, monospace">11111111-1111-4111-8111-111111111111</dd><dt style="color:var(--text-secondary)">Public key</dt><dd style="margin:0;font-family:ui-monospace, monospace;word-break:break-all">ed25519:aa</dd><dt style="color:var(--text-secondary)">Health</dt><dd style="margin:0;color:#22c55e;font-weight:600">Healthy</dd><dt style="color:var(--text-secondary)">Last health check</dt><dd style="margin:0">24.5.2026, 14:00:00</dd><dt style="color:var(--text-secondary)">Last cert issued</dt><dd style="margin:0">24.5.2026, 14:01:00</dd></dl><div style="margin-top:20px"><div style="display:flex;align-items:center;gap:8px;margin-bottom:8px"><strong style="font-size:13px">Recent remote logs</strong><button type="button" data-testid="replica-fetch-logs" style="padding:4px 10px;font-size:11px;border-radius:6px;border:1px solid var(--border)">Fetch logs</button></div><p style="color:var(--text-secondary);font-size:12px;margin:0">Logs are fetched on demand via SSH (not streamed).</p></div></div></div>"`;
