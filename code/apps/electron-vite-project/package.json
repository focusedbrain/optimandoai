{
  "name": "electron-vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "rebuild": "powershell -Command \"Get-Process | Where-Object { $_.ProcessName -match 'DeskT' } | Stop-Process -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2; Remove-Item -Recurse -Force 'C:\\build-output\\latest\\win-unpacked' -ErrorAction SilentlyContinue\" && vite build && electron-builder",
    "dist": "node -e \"const fs=require('fs');['dist','dist-electron'].forEach(d=>{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true});console.log('Cleaned '+d)}})\" && tsc && vite build && electron-builder",
    "dist:clean": "node -e \"const fs=require('fs');['dist','dist-electron'].forEach(d=>{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true});console.log('Cleaned '+d)}})\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "diagnose": "node scripts/diagnose-websocket.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@repo/ingestion-core": "workspace:*",
    "@noble/post-quantum": "^0.2.1",
    "@types/express": "^5.0.5",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/imap": "^0.8.42",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.4",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.10.0",
    "body-parser": "^2.2.0",
    "canvas": "3.2.0",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "imap": "^0.8.19",
    "jose": "^5.2.0",
    "keytar": "^7.9.0",
    "libsodium-wrappers": "^0.7.11",
    "mailparser": "^3.9.0",
    "nodemailer": "^7.0.11",
    "open": "^8.4.2",
    "pdfjs-dist": "4.10.38",
    "pg": "^8.16.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.22.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "^0.1.37",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "node-addon-api": "^7.1.1",
    "prebuild-install": "^7.1.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "ws": "^8.18.3"
  },
  "main": "dist-electron/main.js"
}
