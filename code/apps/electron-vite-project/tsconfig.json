{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@repo/shared-beap-ui": ["../../packages/shared-beap-ui/src/index.ts"],
      "@ext/*": ["../extension-chromium/src/*"],
      "@ext/handshake/handshakeRpc": ["src/shims/handshakeRpc"],
      "@ext/vault/hsContextProfilesRpc": ["src/shims/hsContextProfilesRpc"],
      "@ext/reconstruction": ["src/shims/reconstruction"],
      "@ext/audit": ["src/shims/audit"],
      "@ext/envelope-evaluation": ["src/shims/envelope-evaluation"],
      "@ext/ingress": ["src/shims/ingress"]
    }
  },
  "include": [
    "src",
    "electron",
    "../extension-chromium/src/beap-messages",
    "../extension-chromium/src/handshake",
    "../extension-chromium/src/shared",
    "../extension-chromium/src/vault/hsContextProfilesRpc.ts"
  ],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
