    "@tensorflow/tfjs": "^4.22.0",
    "dompurify": "^3.3.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "webextension-polyfill": "^0.12.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4",
    "zustand": "^5.0.9"
  }
