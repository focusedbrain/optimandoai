{
  "name": "@repo/beap-pod",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "pnpm --filter @repo/beap-cert build && pnpm build && vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "docker:build": "cd ../.. && podman build -t beap-components:dev -f packages/beap-pod/Containerfile ."
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/post-quantum": "^0.2.1",
    "@repo/beap-cert": "workspace:*",
    "@repo/ingestion-core": "workspace:*",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
