# BEAP Pod — Structural validator + HTTP server
# Build from repo root: podman build -t wrdesk-pod -f packages/beap-pod/Containerfile .
# Run: podman run -p 17180:17180 wrdesk-pod

FROM node:20-alpine AS builder
WORKDIR /build

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/beap-pod/ packages/beap-pod/

RUN corepack enable pnpm \
  && pnpm install --frozen-lockfile \
  && pnpm --filter @repo/beap-pod build

FROM node:20-alpine

RUN addgroup -g 1000 -S beap && adduser -u 1000 -S beap -G beap

WORKDIR /app

COPY --from=builder /build/package.json /build/pnpm-lock.yaml /build/pnpm-workspace.yaml ./
COPY --from=builder /build/packages/beap-pod/ packages/beap-pod/
COPY --from=builder /build/node_modules/ node_modules/

ENV POD_PORT=17180
ENV POD_VERSION=1.0.0

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:17180/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

EXPOSE 17180

USER beap

CMD ["node", "packages/beap-pod/dist/index.js"]
