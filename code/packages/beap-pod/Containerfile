# BEAP components pod — single image, role-dispatched
#
# Build from repo root:
#   podman build -t beap-components:dev -f packages/beap-pod/Containerfile .
#
# Run a specific role:
#   podman run --rm -e BEAP_ROLE=ingestor  beap-components:dev
#   podman run --rm -e BEAP_ROLE=validator beap-components:dev
#   podman run --rm -e BEAP_ROLE=depackager beap-components:dev
#   podman run --rm -e BEAP_ROLE=sealer    beap-components:dev
#   podman run --rm -e BEAP_ROLE=certifier beap-components:dev
#   podman run --rm -e BEAP_ROLE=verifier  beap-components:dev
#   podman run --rm -e BEAP_ROLE=mail-fetcher beap-components:dev
#
# Digest pinned: node:20-alpine (2026-04-15, multi-arch index)
# Refresh with: podman manifest inspect docker.io/library/node:20-alpine | jq -r '.config.digest'

# ── stage 1: builder ──────────────────────────────────────────────────────────
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS builder

WORKDIR /build

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/beap-pod/ packages/beap-pod/
COPY packages/beap-cert/ packages/beap-cert/
COPY packages/ingestion-core/ packages/ingestion-core/
COPY packages/email-fetch/ packages/email-fetch/

RUN corepack enable pnpm \
  && pnpm install --frozen-lockfile \
  && pnpm --filter @repo/ingestion-core build \
  && pnpm --filter @repo/beap-cert build \
  && pnpm --filter @repo/email-fetch build \
  && pnpm --filter @repo/beap-pod build

# ── stage 2: runtime ─────────────────────────────────────────────────────────
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293

# Non-root user uid=10100 gid=10100 (Strategy §1.3)
RUN addgroup -g 10100 -S beap \
  && adduser  -u 10100 -S beap -G beap

WORKDIR /app

COPY --from=builder /build/package.json /build/pnpm-lock.yaml /build/pnpm-workspace.yaml ./
COPY --from=builder /build/packages/beap-pod/ packages/beap-pod/
COPY --from=builder /build/packages/beap-cert/ packages/beap-cert/
COPY --from=builder /build/packages/ingestion-core/ packages/ingestion-core/
COPY --from=builder /build/packages/email-fetch/ packages/email-fetch/
COPY --from=builder /build/node_modules/ node_modules/

# Copy the role dispatcher — must be executable
COPY --chmod=0755 packages/beap-pod/entrypoint.sh /app/entrypoint.sh

ENV POD_PORT=17180
ENV POD_VERSION=1.0.0
# BEAP_ROLE must be set by the pod manifest per container
# (ingestor|validator|depackager|sealer|certifier|verifier|mail-fetcher).
# Per-role uids (10100..10106) are assigned in pod manifests (P3.3/P3.5/P4.5.6), not here.
# mail-fetcher uses uid 10106 (extends the 10100–10105 range from P1.1).
ENV BEAP_ROLE=""

# HEALTHCHECK note (tracked in phase-1-tracker.md § P1.1):
# No HEALTHCHECK instruction here. Role stubs (P1.1) have no HTTP server.
# Liveness / readiness probes are defined per-container in pod.yaml instead.
# A per-role HEALTHCHECK can be added to this Containerfile once the real
# role HTTP servers are implemented (P1.3–P1.6).

EXPOSE 17180

USER beap

ENTRYPOINT ["/app/entrypoint.sh"]
